# Скопируйте в .env и подставьте свои значения (файл .env в git не коммитится).
# Supabase → Project Settings → API: Project URL и anon public key (не service role / secret).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Локальная разработка без затрагивания «боевой» базы (и правок в Dashboard к тому же проекту):
# создайте отдельный проект в Supabase (staging / dev), скопируйте этот файл в .env.local и укажите там
# другие VITE_SUPABASE_* . Vite подхватывает .env.local поверх .env — отдельного переключателя «синхронизации
# с админкой» в приложении нет: и клиент, и Table Editor работают с одной и той же БД выбранного проекта.

# Полностью без Supabase: UI и данные в браузере (localStorage). Удобно для вёрстки и логики без сети.
# В .env.local добавьте строку ниже и перезапустите npm run dev. Уберите или поставьте 0 — снова нужен VITE_SUPABASE_* .
# VITE_LOCAL_DEV_MOCK=1

# Только в dev: экран входа, но подойдёт любой email и пароль; данные как у мока (localStorage). Supabase не вызывается.
# VITE_DEV_LOGIN_ANY=1
