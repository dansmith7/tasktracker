# Скопируйте этот файл в .env.backup и подставьте пароль (файл .env.backup в git не коммитится).
#
# Supabase → Project Settings → Database:
#   Connection string → URI → режим "Direct connection" (не pooler, если pg_dump ругается).
# Формат:
#   postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Пароль — "Database password" на той же странице (или сбросьте через "Reset database password").

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
